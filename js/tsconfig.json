{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "ESNext.Disposable", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowJs": true
  },
  "include": [
    "src/**/*.ts",
    "wasm-simd-mt/sunspot_wasm.d.ts",
    "wasm-simd-st/sunspot_wasm.d.ts",
    "wasm-sisd-mt/sunspot_wasm.d.ts",
    "wasm-sisd-st/sunspot_wasm.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
